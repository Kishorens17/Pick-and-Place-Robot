<?xml version="1.0" ?>
<robot name="pick_place_arm">
  
  <!-- Define materials -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="1.0 1.0 0.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  
  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.08" radius="0.12"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.08" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  
  <!-- Joint 1 (Base rotation) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>
  
  <!-- Link 1 (Vertical column) - LONGER -->
  <link name="link_1">
    <visual>
      <geometry>
        <box size="0.08 0.08 0.5"/>
      </geometry>
      <origin xyz="0 0 0.25"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.08 0.5"/>
      </geometry>
      <origin xyz="0 0 0.25"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.25"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  
  <!-- Joint 2 (Shoulder) -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>
  
  <!-- Link 2 (Upper arm - horizontal) - LONGER -->
  <link name="link_2">
    <visual>
      <geometry>
        <box size="0.5 0.06 0.06"/>
      </geometry>
      <origin xyz="0.25 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 0.06 0.06"/>
      </geometry>
      <origin xyz="0.25 0 0"/>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0.25 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
    </inertial>
  </link>
  
  <!-- Joint 3 (Elbow) -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100" velocity="1.0"/>
  </joint>
  
  <!-- Link 3 (Forearm) - LONGER -->
  <link name="link_3">
    <visual>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <origin xyz="0.2 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <origin xyz="0.2 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0.2 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>
  
  <!-- Joint 4 (Wrist) -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="1.5"/>
  </joint>
  
  <!-- Link 4 (Wrist connector - points down) - LONGER -->
  <link name="link_4">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
      <origin xyz="0 0 -0.075"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
      <origin xyz="0 0 -0.075"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.075"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- Gripper connection joint -->
  <joint name="gripper_joint" type="fixed">
    <parent link="link_4"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
  </joint>
  
  <!-- Gripper base (palm) - LARGER -->
  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.06 0.10 0.03"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.10 0.03"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- Left finger - LONGER -->
  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.025 0.020 0.10"/>
      </geometry>
      <origin xyz="0 0 -0.05"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.020 0.10"/>
      </geometry>
      <origin xyz="0 0 -0.05"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <!-- Right finger - LONGER -->
  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.025 0.020 0.10"/>
      </geometry>
      <origin xyz="0 0 -0.05"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.020 0.10"/>
      </geometry>
      <origin xyz="0 0 -0.05"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <!-- Left finger joint -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0 0.03 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="10" velocity="0.5"/>
  </joint>
  
  <!-- Right finger joint -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0 -0.03 -0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.04" upper="0.0" effort="10" velocity="0.5"/>
    <mimic joint="left_finger_joint" multiplier="-1.0" offset="0"/>
  </joint>
  
  <!-- End effector frame -->
  <joint name="ee_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="ee_link"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
  </joint>
  
  <link name="ee_link">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
</robot>