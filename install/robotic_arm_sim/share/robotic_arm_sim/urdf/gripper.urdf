<?xml version="1.0" ?>
<robot name="gripper_module">
  
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  
  <!-- Gripper base (palm) -->
  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.06 0.06 0.02"/>
      </geometry>
      <origin xyz="0 0 -0.01"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.06 0.02"/>
      </geometry>
      <origin xyz="0 0 -0.01"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- Left finger -->
  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.02 0.015 0.08"/>
      </geometry>
      <origin xyz="0 0.025 0.03"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.015 0.08"/>
      </geometry>
      <origin xyz="0 0.025 0.03"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0.025 0.03"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- Right finger -->
  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.02 0.015 0.08"/>
      </geometry>
      <origin xyz="0 -0.025 0.03"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.015 0.08"/>
      </geometry>
      <origin xyz="0 -0.025 0.03"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 -0.025 0.03"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- Left finger joint -->
  <joint name="left_finger_joint" type="revolute">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>
  
  <!-- Right finger joint (mimic - moves opposite to left finger) -->
  <joint name="right_finger_joint" type="revolute">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
    <mimic joint="left_finger_joint" multiplier="-1.0" offset="0"/>
  </joint>
  
</robot>